        id: String,
        vector: [Float],
        ctx: CompressionContext
    ) {

        ingestCounter += 1
        let timestamp = ingestCounter

        let instability = ctx.entropy
        let confidence = deriveConfidence(ctx)
        let reliability = ctx.reliability

        let decision = policy.evaluate(
            instability: instability,
            confidence: confidence,
            reliability: reliability
        )

        // =================================================
        // FULL TRACE AUDIT (INCLUDING REJECTS)
        // =================================================

        emitAudit(
            zone: .ingest,
            id: id,
            confidence: confidence,
            instability: instability,
            decision: decision,
            timestamp: timestamp
        )

        // =================================================
        // POLICY GATE
        // =================================================

        if case .reject(let reason) = decision {
            emitAudit(
                zone: .audit,
                id: id,
                confidence: confidence,
                instability: instability,
                decision: .reject(reason),
                timestamp: timestamp
            )
            return
        }

        var working = vector

        switch decision {
        case .degrade(let f):
            working = working.map { $0 * f }

        case .mutate(let f):
            working = mutate(working, factor: f)

        default:
            break
        }

        // deterministic speculation
        if confidence > 0.4, instability < policy.maxInstability {
            working = working.map { $0 + rng.nextFloat() * 0.01 }
        }

        let anchor = Anchor(
            id: id,
            values: working,
            indices: Array(working.indices),
            denseCache: working,
            version: Int(ingestCounter),
            timestamp: timestamp,
            originalSize: vector.count
        )

        let envelope = DeterministicEnvelope(
            anchor: anchor,
            entropy: ctx.entropy,
            drift: ctx.drift,
            isBurst: false,
            phase: "active",
            speculationApplied: true,
            speculationConfidence: confidence,
            ingestIndex: Int(ingestCounter),
            timestamp: timestamp,
            checksum: hash(id: id, t: timestamp)
        )

        auditChain.append(envelope.checksum)
    }

    // =====================================================
