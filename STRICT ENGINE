// =====================================================

public final class DUMEHybridPlusEngine {

    private let crypto: CryptoHashing
    private let policy: ProbabilisticPolicyV1

    private var rng = VerifiableRNG(seed: 0xBADC0FFEE)
    private var ingestCounter: UInt64 = 0

    // SHARDED AUDIT (NO SINGLE SOURCE OF TRUTH)
    private var shards: [TrustZone: AuditShard] = [
        .ingest: AuditShard(crypto: SimpleHasher()),
        .storage: AuditShard(crypto: SimpleHasher()),
        .audit: AuditShard(crypto: SimpleHasher())
    ]

    public init(
        crypto: CryptoHashing = SimpleHasher(),
        policy: ProbabilisticPolicyV1 = .init(
            maxInstability: 0.75,
            minConfidence: 0.4,
            sourceReliabilityGate: 0.6
        )
    ) {
        self.crypto = crypto
        self.policy = policy
    }

    // =====================================================
    // MARK: - INGEST PIPELINE (DVSM)
    // =====================================================

    public func ingest(
        id: String,
        vector: [Float],
        instability: Float,
        confidence: Float,
        reliability: Float,
        node: NodeContext
    ) -> NIZKProof {

        ingestCounter += 1

        let decision = policy.evaluate(
            instability: instability,
            confidence: confidence,
            reliability: reliability
        )

        let adjusted = applyDecision(vector, decision: decision)

        let payload = "ID:\(id)|NODE:\(node.nodeID)|DEC:\(decision)"

        let hash = shards[.ingest]!.append(id: id, payload: payload)

        // =================================================
        // REJECTION IS NOW FULLY TRACEABLE (FIXED GAP)
        // =================================================

        let proof = NIZKProof(
            decision: decision,
            proofHash: hash
        )

        return proof
    }

    // =====================================================
    // MARK: - DECISION ENGINE (DETERMINISTIC VRF STYLE)
    // =====================================================

    private func applyDecision(
        _ vector: [Float],
        decision: ProbabilisticDecision
    ) -> [Float] {

        switch decision {

        case .accept:
            return vector

        case .degrade(let f):
            return vector.map { $0 * f }

        case .mutate(let f):
            return vector.map { $0 + rng.next() * f }

        case .reject:
            // IMPORTANT: still deterministic transformation (no silent drop)
            return vector.map { _ in 0.0 }
        }
    }

    // =====================================================
    // MARK: - DVSM GLOBAL RECONCILIATION (GOSSIP LAYER)
    // =====================================================

    public func reconcile() -> String {

        let ingestRoot = shards[.ingest]!.rootHash()
        let storageRoot = shards[.storage]!.rootHash()
        let auditRoot = shards[.audit]!.rootHash()

        let globalFingerprint = ingestRoot + "|" + storageRoot + "|" + auditRoot

        return crypto.hash(Data(globalFingerprint.utf8))
    }
}
