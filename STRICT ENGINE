public enum ProbabilisticDecision: Sendable, CustomStringConvertible {
    case accept
    case degrade(Float)
    case mutate(Float)
    case reject(String)

    public var description: String {
        switch self {
        case .accept: return "ACCEPT"
        case .degrade(let f): return "DEGRADE(\(f))"
        case .mutate(let f): return "MUTATE(\(f))"
        case .reject(let r): return "REJECT(\(r))"
        }
    }
}

// =====================================================
// MARK: - POLICY
// =====================================================

public struct ProbabilisticPolicyV1: Sendable {

    public let policyID: String
    public let maxInstability: Float
    public let minConfidence: Float
    public let sourceReliabilityGate: Float

    public init(
        id: String = "hybrid++-policy",
        instability: Float = 0.75,
        confidence: Float = 0.4,
        reliability: Float = 0.6
    ) {
        self.policyID = id
        self.maxInstability = instability
        self.minConfidence = confidence
        self.sourceReliabilityGate = reliability
    }

    public func evaluate(
        instability: Float,
        confidence: Float,
        reliability: Float
    ) -> ProbabilisticDecision {

        if instability > maxInstability * 1.5 {
            return .reject("CRITICAL_INSTABILITY")
        }

        if reliability < sourceReliabilityGate {
            return .degrade(0.4)
        }

        if confidence < minConfidence {
            return .mutate(0.6)
        }

        if instability > maxInstability {
            return .degrade(0.7)
        }

        return .accept
    }
}

