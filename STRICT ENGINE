public struct MerkleNode: Sendable {
    public let id: String
    public let hash: String
    public let prevHash: String?
}

// =====================================================
// MARK: - AUDIT SHARD (NO GLOBAL STATE)
// =====================================================

public final class AuditShard {

    private let crypto: CryptoHashing
    private(set) var chain: [MerkleNode] = []

    public init(crypto: CryptoHashing) {
        self.crypto = crypto
    }

    public func append(id: String, payload: String) -> String {

        let prev = chain.last?.hash
        let data = Data((prev ?? "GENESIS" + "|" + payload).utf8)

        let hash = crypto.hash(data)

        let node = MerkleNode(
            id: id,
            hash: hash,
            prevHash: prev
        )

        chain.append(node)
        return hash
    }

    public func rootHash() -> String {
        chain.last?.hash ?? "GENESIS"
    }
}

