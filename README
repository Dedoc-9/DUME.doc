## Hybrid Engine
```swift

Strict Engine:

let engine = DUMEHybridEngine(
    metric: metric,
    storage: storage,
    enableEvolution: true,
    enableSpeculation: true
)

try await engine.ingest(
    id: "vec-1",
    vector: embedding,
    ctx: context
)
